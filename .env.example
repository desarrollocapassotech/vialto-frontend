# Clerk (misma cuenta que el backend; publishable en frontend)
VITE_CLERK_PUBLISHABLE_KEY=

# URL base del API en producción (ej. https://api.tudominio.com) — sin barra final.
# En desarrollo se deja vacío y Vite hace proxy de /api → http://localhost:8080
VITE_API_URL=

# Opcional: destino del proxy en dev (default localhost:8080)
# VITE_API_PROXY_TARGET=http://localhost:8080

# Sentry (opcional)
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
