# Clerk (misma cuenta que el backend; publishable en frontend)
VITE_CLERK_PUBLISHABLE_KEY=

# Origen del backend sin barra final. En local, si no lo ponés, el front usa
# http://localhost:8080 y las peticiones van directo al Nest (evita 404 del proxy).
# VITE_API_URL=http://localhost:8080

# Sentry (opcional)
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
